	)
	(text "- Basically connect chips to header pins\n- Look at datasheets, evaluation boards,\n  breakouts by companies that provide schematics\n  (like Adafruit and Sparkfun) for these particular ICs\n- Make sure chips share buses as much as possible (I2C preferred)\n- Make sure all complementary components and decoupling capacitors are connected\n- Add a power indicator LED, I2C pull-up resistors, and interrupt pull-up resistors if necessary\n- Header breakout should have VDD, GND, SCL, SDA, interrupts\n- Board is designed to work with 3.3v power and logic, logic level converters\n  and voltage regulators like those included on the adafruit boards are not necessary unless\n  one component requires 1.8v power and logic\n- End goal is a breakout board like https://www.adafruit.com/product/3387\n  but with multiple chips instead of one\n"
		(exclude_from_sim no)
		(at 20.574 42.926 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "663da55d-c50b-480f-ab9c-57b8556ad8e3")
	)
	(text "Instructions\n"
		(exclude_from_sim no)
		(at 40.386 22.86 0)
		(effects
			(font
				(size 5.08 5.08)
				(thickness 1.016)
				(bold yes)
				(color 13 176 50 1)
			)
		)
		(uuid "681167e4-6a14-4eaa-8cd1-c02298da81d4")
	)
	(text "Two gyros since BMI088 does not have any flight data but was recommended by mlyle (NyanSat lead)\nLSM6 has some flight history (it's close to the IMU inside the Pixel 7 Pro which flew on SatGus)\nbut I don't have any experience with it"
		(exclude_from_sim no)
		(at 24.13 64.008 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "e75f5267-c318-4003-a75d-62f378e79486")
	)
